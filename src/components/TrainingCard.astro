---
interface Props { title: string; eyebrow: string; description: string; href: string; }
const { title, eyebrow, description, href } = Astro.props;
---
<article class="group flex h-full flex-col rounded-md border border-lifeline-blueLight bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
  <p class="text-xs font-black uppercase tracking-[0.18em] text-lifeline-orange">{eyebrow}</p>
  <h3 class="mt-4 text-2xl font-black text-lifeline-blueDark">{title}</h3>
  <p class="mt-3 flex-1 leading-7 text-lifeline-muted">{description}</p>
  <a href={href} class="focus-ring mt-6 inline-flex font-bold text-lifeline-blue group-hover:text-lifeline-orange">Bekijk training</a>
</article>
